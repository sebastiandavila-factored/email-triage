GROQ_API_KEY=secretKeyExample123
API_KEY=dev-local-key
LOGFIRE_TOKEN=
LOGFIRE_SAMPLE_RATE=1.0
LOGFIRE_ENVIRONMENT=dev
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/email_triage

# Google OAuth2 SSO — leave empty to disable
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/callback
SESSION_SECRET=replace-with-32-random-bytes-hex
ACCESS_TOKEN_EXPIRE_MINUTES=30
FRONTEND_URL=http://localhost:5173

# CORS — leave empty in dev (Vite proxy = same-origin). In prod set to the
# deployed frontend origin(s) as a JSON array:
# CORS_ORIGINS=["https://email-triage.vercel.app"]
CORS_ORIGINS=[]
